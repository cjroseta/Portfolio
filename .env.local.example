# GitHub (server-only variables)
# The token is optional for public repositories, but increases the request limit.
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_github_token

# OpenWeatherMap (currently used in the browser; restrict the key by domain)
# https://openweathermap.org/api
NEXT_PUBLIC_WEATHER_API_KEY=your_key

# ExchangeRate API (currently used in the browser; restrict the key by domain)
# https://www.exchangerate-api.com
NEXT_PUBLIC_EXCHANGE_API_KEY=your_key

# Server API routes
ALPHA_VANTAGE_API_KEY=your_key
# Currently read by the NewsAPI route; it will be moved to a server-only key in Phase 7.
NEXT_PUBLIC_NEWS_API_KEY=your_key
