# GitHub (não precisa de token para repos públicos, mas aumenta o rate limit)
NEXT_PUBLIC_GITHUB_USERNAME=seu_username_aqui
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# OpenWeatherMap - https://openweathermap.org/api (grátis)
NEXT_PUBLIC_WEATHER_API_KEY=sua_chave_aqui

# ExchangeRate API - https://exchangerate-api.com (grátis 1500 req/mês)
NEXT_PUBLIC_EXCHANGE_API_KEY=sua_chave_aqui
